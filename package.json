{
  "name": "rental-listings-platform",
  "private": true,
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "install:all": "npm install --workspaces",
